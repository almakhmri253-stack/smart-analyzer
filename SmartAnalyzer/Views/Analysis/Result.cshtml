// ── Close all open dropdowns then capture ──
function closeDropdownsThen(fn) {
    document.querySelectorAll('.dropdown-menu.show').forEach(m => {
        const toggle = m.previousElementSibling;
        if (toggle) bootstrap.Dropdown.getInstance(toggle)?.hide();
    });
    setTimeout(fn, 200);
