// ── Export compliance chart ──
function doExportCompliance() {
    closeDropdownsThen(async () => {
        const card = document.getElementById('complianceCard');
        if (!card) { showToast('المخطط غير جاهز بعد', 'danger'); return; }
        try {
            const cvs = await html2canvas(card, { scale: 2, useCORS: true, backgroundColor: '#ffffff' });
            const link = document.createElement('a');
            link.download = 'compliance-' + new Date().toISOString().slice(0,10) + '.png';
            link.href = cvs.toDataURL('image/png', 1.0);
            document.body.appendChild(link); link.click(); document.body.removeChild(link);
            showToast('✓ تم تصدير المخطط', 'success');
        } catch(e) { showToast('خطأ في التصدير: ' + e.message, 'danger'); }
    });
}

// ── PDF Export ─────────────────────────────────────────────────
function exportCardPDF(cardId, filename) {
    closeDropdownsThen(async () => {
    const card = document.getElementById(cardId);
    if (!card) { showToast('العنصر غير موجود', 'danger'); return; }
    showToast('جاري إنشاء PDF...', 'info');
    try {
        const cvs = await html2canvas(card, { scale: 2, useCORS: true, backgroundColor: '#ffffff' });
        const imgData = cvs.toDataURL('image/png', 1.0);
        const { jsPDF } = window.jspdf;
        const w = cvs.width / 2, h = cvs.height / 2;
        const pdf = new jsPDF({ orientation: w > h ? 'landscape' : 'portrait', unit: 'px', format: [w, h] });
        pdf.addImage(imgData, 'PNG', 0, 0, w, h);
        pdf.save(filename + '-' + new Date().toISOString().slice(0, 10) + '.pdf');
        showToast('✓ تم تصدير PDF', 'success');
    } catch(e) { showToast('خطأ: ' + e.message, 'danger'); }
    });
}

async function exportPDF() {
    showToast('جاري إنشاء التقرير...', 'info');
    try {
        const { jsPDF } = window.jspdf;
        const pdf = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
        const pageW = pdf.internal.pageSize.getWidth();
        const pageH = pdf.internal.pageSize.getHeight();
        const margin = 10, usableW = pageW - margin * 2;

        pdf.setFont('helvetica', 'bold');
        pdf.setFontSize(15);
        pdf.text('Smart Analyzer - Analysis Report', pageW / 2, 18, { align: 'center' });
        pdf.setFontSize(9);
        pdf.setFont('helvetica', 'normal');
        pdf.text(new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }), pageW / 2, 26, { align: 'center' });

        let y = 34;
        for (const [id, name] of [['complianceCard','Compliance Chart'],['crossTabCard','Cross-Tab Chart']]) {
            const el = document.getElementById(id);
            if (!el) continue;
            pdf.setFontSize(10); pdf.setFont('helvetica', 'bold');
            pdf.text(name, margin, y + 5); y += 8;
            const cvs = await html2canvas(el, { scale: 2, useCORS: true, backgroundColor: '#ffffff' });
            const imgH = (cvs.height / cvs.width) * usableW;
            if (y + imgH > pageH - margin) { pdf.addPage(); y = margin; }
            pdf.addImage(cvs.toDataURL('image/png', 1.0), 'PNG', margin, y, usableW, imgH);
            y += imgH + 10;
        }

        pdf.save('analysis-report-' + new Date().toISOString().slice(0, 10) + '.pdf');
        showToast('✓ تم تصدير التقرير', 'success');
    } catch(e) { showToast('خطأ: ' + e.message, 'danger'); }
}

async function exportAll() {
    await exportExcel();
    setTimeout(exportPDF, 800);
}

// ── Export cross-tab chart ──
function doExportCrossTab() {
    closeDropdownsThen(async () => {
        const card = document.getElementById('crossTabCard');
        if (!card) { showToast('المخطط غير جاهز بعد', 'danger'); return; }
        try {
            const cvs = await html2canvas(card, { scale: 2, useCORS: true, backgroundColor: '#ffffff' });
            const link = document.createElement('a');
            link.download = 'cross-tab-' + new Date().toISOString().slice(0,10) + '.png';
            link.href = cvs.toDataURL('image/png', 1.0);
            document.body.appendChild(link); link.click(); document.body.removeChild(link);
            showToast('✓ تم تصدير المخطط', 'success');
        } catch(e) { showToast('خطأ في التصدير: ' + e.message, 'danger'); }
    });
}
</script>
