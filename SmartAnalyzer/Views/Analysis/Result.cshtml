// ── Toast ──────────────────────────────────────────────────────
function showToast(msg, type = 'success') {
    const colors = { success: '#10b981', danger: '#ef4444', info: '#2563eb' };
    const t = document.createElement('div');
    t.style.cssText = `position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);
        background:${colors[type]||colors.success};color:white;padding:.75rem 1.5rem;
        border-radius:10px;font-weight:700;z-index:99999;font-family:Cairo,sans-serif;
        box-shadow:0 4px 20px rgba(0,0,0,0.2);transition:opacity .4s`;
    t.textContent = msg;
    document.body.appendChild(t);
    setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.remove(), 400); }, 2500);
}

function showLoading(show) {
    document.getElementById('loadingOverlay').style.display = show ? 'flex' : 'none';
}

// ── Total KPI Cards ────────────────────────────────────────────
const VALUE_COL = 'Total Contract Value(USD)';

function refreshMainCharts() {
    if (!lastResult) return;
    const total = lastResult.totalCount ?? 0;
    const s     = lastResult.summary   ?? {};

    // KPI 1 — contract count
    document.getElementById('kpiContractCount').textContent = total.toLocaleString(locale());
    document.getElementById('kpiContractSub').textContent =
        getConditions().length
            ? `${t('j.filtered_from')} ${Model_TotalRows.toLocaleString(locale())}`
            : t('j.total_records');

    // KPI 2 — Total Contract Value(USD) sum
    const sum = s[VALUE_COL + '_sum'] ?? 0;
    document.getElementById('kpiContractValue').textContent =
        sum ? '$ ' + Number(sum).toLocaleString(locale(), {maximumFractionDigits: 2}) : '—';
    document.getElementById('kpiContractValueSub').textContent = t('a.kpi_sub_value');
}

function formatBigValue(n) {
    const ar = locale() === 'ar-SA';
    if (Math.abs(n) >= 1e9) return (n/1e9).toFixed(2) + (ar ? ' مليار' : 'B');
    if (Math.abs(n) >= 1e6) return (n/1e6).toFixed(2) + (ar ? ' مليون' : 'M');
    if (Math.abs(n) >= 1e3) return (n/1e3).toFixed(1) + (ar ? ' ألف' : 'K');
    return Number(n).toLocaleString(locale(), {maximumFractionDigits: 2});
}

// ── Entity Cards ───────────────────────────────────────────────
const CARD_COLORS = [
    ['#3b82f6','#1d4ed8'],['#10b981','#047857'],['#f59e0b','#b45309'],
    ['#ef4444','#b91c1c'],['#8b5cf6','#6d28d9'],['#06b6d4','#0e7490'],
    ['#ec4899','#be185d'],['#84cc16','#4d7c0f'],['#f97316','#c2410c'],
    ['#14b8a6','#0f766e'],['#a78bfa','#7c3aed'],['#fb923c','#ea580c']
];

let activeEntityFilter = null;

async function loadEntityCards() {
    const col = document.getElementById('entityColSelect')?.value;
    if (!col) return;

    document.getElementById('entitySectionLabel').textContent = col;
    document.getElementById('entityCardsRow').innerHTML =
        `<div class="entity-card"><div class="entity-avatar" style="background:rgba(255,255,255,0.2)">
         <i class="fas fa-spinner fa-spin"></i></div><div class="entity-name">${t('j.loading')}</div></div>`;

    const resp = await fetch('/Analysis/EntityCards', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            fileId: FILE_ID, column: col,
            conditions: getConditions(),
            logicOperator: document.getElementById('logicOperator').value
        })
    });
    const cards = await resp.json();

    if (!cards.length) {
        document.getElementById('entityCardsRow').innerHTML =
            `<div style="color:rgba(255,255,255,.6);font-size:.85rem;padding:.5rem">${t('j.no_data')}</div>`;
        return;
    }

    document.getElementById('entityTotalBadge').textContent = cards.length;
    const maxCount = cards[0].count;

    const total = cards.reduce((a, c) => a + c.count, 0);
    const allCard = `
    <div class="entity-card ${!activeEntityFilter ? 'active' : ''}"
         style="background:linear-gradient(135deg,#475569,#1e293b)"
         onclick="filterByEntity(null,'${col}')">
        <div class="entity-name"><i class="fas fa-th-large me-1" style="font-size:.72rem"></i>${t('j.all')}</div>
        <div class="entity-count"><strong>${total.toLocaleString(locale())}</strong> ${t('j.records')}</div>
        <div class="entity-bar"><div class="entity-bar-fill" style="width:100%;background:rgba(255,255,255,0.5)"></div></div>
    </div>`;

    const cardHtml = cards.map((c, i) => {
        const [c1, c2] = CARD_COLORS[i % CARD_COLORS.length];
        const pct = maxCount > 0 ? Math.round(c.count / maxCount * 100) : 0;
        const isActive = activeEntityFilter === c.name;
        return `
        <div class="entity-card ${isActive ? 'active' : ''}"
             style="background:linear-gradient(135deg,${c1},${c2})"
             onclick="filterByEntity('${c.name.replace(/'/g,"\\'")}','${col}')">
            <div class="entity-name" title="${c.name}">${c.name}</div>
            <div class="entity-count"><strong>${c.count.toLocaleString(locale())}</strong> · ${Number(c.percentage).toLocaleString(locale())}%</div>
            <div class="entity-bar"><div class="entity-bar-fill" style="width:${pct}%;background:rgba(255,255,255,0.6)"></div></div>
        </div>`;
    }).join('');

    document.getElementById('entityCardsRow').innerHTML = allCard + cardHtml;
}

function filterByEntity(value, col) {
    activeEntityFilter = value;
    // Update active state visually
    document.querySelectorAll('.entity-card').forEach(c => c.classList.remove('active'));
    event.currentTarget.classList.add('active');

    // Clear existing entity filter condition, then add new one
    const container = document.getElementById('filtersContainer');
    // Remove old entity filter rows
    Array.from(container.querySelectorAll('.filter-row')).forEach(row => {
        const colSel = row.querySelector('.col-select');
        if (colSel?.value === col) row.remove();
    });

    if (value) {
        addFilter();
        const rows = container.querySelectorAll('.filter-row');
        const lastRow = rows[rows.length - 1];
        const colSel = lastRow.querySelector('.col-select');
        colSel.value = col;
        updateOps(colSel);
        lastRow.querySelector('.op-select').value = '=';
        lastRow.querySelector('.val1').value = value;
    }

    updateConditionsCount();
    runAll(1);
}

// ── Cross-Tab Chart ─────────────────────────────────────────────
let crossTabChartInst = null;
let crossTabChartType = 'bar';

function setCrossTabType(btn) {
    btn.closest('.btn-group').querySelectorAll('.chart-type-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    crossTabChartType = btn.dataset.type;
    drawCrossTabChart();
}

async function drawCrossTabChart() {
    const col1 = document.getElementById('crossCol1')?.value;
    const col2 = document.getElementById('crossCol2')?.value;
    if (!col1 || !col2) return;

    const resp = await fetch('/Analysis/CrossTab', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            fileId: FILE_ID, col1, col2,
            conditions: getConditions(),
            logicOperator: document.getElementById('logicOperator').value
        })
    });
    const ct = await resp.json();

    if (!ct.categories?.length || !ct.series?.length) return;

    if (crossTabChartInst) crossTabChartInst.destroy();
    const ctx = document.getElementById('crossTabChart').getContext('2d');
    const isCircular = ['pie','doughnut','polarArea'].includes(crossTabChartType);

    const datasets = ct.series.map((s, i) => ({
        label: s.name,
        data: s.values,
        backgroundColor: PALETTE[i % PALETTE.length] + (isCircular ? '' : 'cc'),
        borderColor: PALETTE[i % PALETTE.length],
        borderWidth: 1.5,
        borderRadius: crossTabChartType === 'bar' ? 5 : 0,
        tension: 0.4,
        fill: false,
        pointRadius: crossTabChartType === 'line' ? 4 : 0
    }));

    crossTabChartInst = new Chart(ctx, {
        type: crossTabChartType,
        data: { labels: ct.categories, datasets },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: {
                legend: {
                    position: 'top',
                    labels: { font: { family: 'Cairo', size: 11 }, boxWidth: 12, padding: 10 }
                },
                tooltip: { callbacks: {
                    label: c => ` ${c.dataset.label}: ${Number(c.raw).toLocaleString(locale())}`
                }},
                datalabels: isCircular ? buildDatalabels(crossTabChartType, true, 9) : {
                    display: (ctx) => ctx.dataset.data[ctx.dataIndex] > 0,
                    color: '#1f2937',
                    backgroundColor: 'rgba(255,255,255,0.8)',
                    borderRadius: 3,
                    padding: { top: 1, bottom: 1, left: 3, right: 3 },
                    font: { family: 'Cairo', size: 8, weight: 'bold' },
                    anchor: 'end', align: 'end', offset: 1,
                    clamp: true,
                    formatter: (v) => Number(v).toLocaleString(locale())
                }
            },
            scales: isCircular ? {} : {
                x: {
                    stacked: false,
                    ticks: { font: { family: 'Cairo', size: 10 }, maxRotation: 40, maxTicksLimit: 15 },
                    grid: { display: false }
                },
                y: {
                    beginAtZero: true,
                    ticks: { font: { family: 'Cairo', size: 10 }, callback: v => Number(v).toLocaleString(locale()) },
                    grid: { color: '#f0f4f8' }
                }
            }
        }
    });
}

// ── Compliance Chart ─────────────────────────────────────────────
function setComplianceType(btn) {
    btn.closest('.btn-group').querySelectorAll('.chart-type-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    complianceChartType = btn.dataset.type;
    drawComplianceChart();
}

async function drawComplianceChart() {
    const col = document.getElementById('complianceCol')?.value;
    if (!col) return;

    const resp = await fetch('/Analysis/EntityCards', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            fileId: FILE_ID, column: col,
            conditions: getConditions(),
            logicOperator: document.getElementById('logicOperator').value
        })
    });
    const cards = await resp.json();

    const legendEl = document.getElementById('complianceLegend');
    if (!cards.length) {
        legendEl.innerHTML = '<div class="text-muted small p-2">لا توجد بيانات</div>';
        return;
    }

    const labels = cards.map(c => c.name);
    const values = cards.map(c => c.count);
    const total  = values.reduce((a, b) => a + b, 0);

    if (complianceChartInst) complianceChartInst.destroy();
    const ctx = document.getElementById('complianceChart').getContext('2d');
    const isCircular = ['pie','doughnut','polarArea'].includes(complianceChartType);

    complianceChartInst = new Chart(ctx, {
        type: complianceChartType,
        data: {
            labels,
            datasets: [{
                label: col,
                data: values,
                backgroundColor: isCircular ? PALETTE : PALETTE.map(p => p + 'cc'),
                borderColor: isCircular ? '#fff' : PALETTE,
                borderWidth: isCircular ? 2 : 1.5,
                borderRadius: complianceChartType === 'bar' ? 6 : 0,
                tension: 0.4
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: { callbacks: {
                    label: c => ` ${Number(c.raw).toLocaleString(locale())} (${Number(total > 0 ? Math.round(c.raw / total * 100) : 0).toLocaleString(locale())}%)`
                }},
                datalabels: isCircular ? {
                    display: (ctx) => ctx.dataset.data[ctx.dataIndex] > 0,
                    color: 'white',
                    textAlign: 'center',
                    clamp: true,
                    font: { family: 'Cairo', size: 9, weight: 'bold' },
                    formatter: (value) => {
                        const pct = total > 0 ? Math.round(value/total*100) : 0;
                        return `${Number(value).toLocaleString(locale())}\n${Number(pct).toLocaleString(locale())}%`;
                    }
                } : {
                    display: (ctx) => ctx.dataset.data[ctx.dataIndex] > 0,
                    color: '#374151',
                    font: { family: 'Cairo', size: 10, weight: 'bold' },
                    anchor: 'end', align: 'end', offset: 2,
                    formatter: (v) => Number(v).toLocaleString(locale())
                }
            },
            scales: isCircular ? {} : {
                x: { ticks: { font: { family: 'Cairo', size: 10 }, maxRotation: 40 }, grid: { display: false } },
                y: { beginAtZero: true, ticks: { font: { family: 'Cairo', size: 10 }, callback: v => Number(v).toLocaleString(locale()) }, grid: { color: '#f0f4f8' } }
            }
        }
    });

    legendEl.innerHTML = cards.map((c, i) => {
        const pct   = total > 0 ? Math.round(c.count / total * 100) : 0;
        const color = PALETTE[i % PALETTE.length];
        return `
        <div style="display:flex;align-items:flex-start;gap:10px;margin-bottom:11px">
            <div style="width:12px;height:12px;border-radius:3px;background:${color};flex-shrink:0;margin-top:3px"></div>
            <div style="flex:1;min-width:0">
                <div style="display:flex;justify-content:space-between;align-items:baseline;gap:8px;margin-bottom:5px">
                    <span style="font-size:.82rem;font-weight:600;color:#111827;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${c.name}</span>
                    <span style="font-size:.78rem;color:#6b7280;white-space:nowrap;flex-shrink:0">${c.count.toLocaleString(locale())} · ${Number(pct).toLocaleString(locale())}%</span>
                </div>
                <div style="height:3px;background:#f1f5f9;border-radius:2px">
                    <div style="height:3px;background:${color};border-radius:2px;width:${pct}%;transition:width .6s ease"></div>
                </div>
            </div>
        </div>`;
    }).join('');
}

